#!/usr/bin/env bash
# Generated by samsara-cli — do not edit manually.
# Hook: {{ hook_name }}
# Event: {{ event }}
set -euo pipefail

# Session start hook for samsara on Codex
# Injects context into the session system message.

# PLUGIN_DIR is a relative path from the project root.
# Assumption: Codex executes hooks from the project working directory.
# If Codex executes from a different directory, PLUGIN_DIR will resolve incorrectly
# and SKILL.md will not be found — injecting "Error reading samsara-bootstrap skill"
# as context instead of empty.
PLUGIN_DIR="{{ plugin_dir }}"
SKILLS_DIR="${PLUGIN_DIR}/{{ skills_dir }}"

# Source any skill-specific environment setup
if [ -d "${SKILLS_DIR}" ]; then
  for skill_env in "${SKILLS_DIR}"/*/env.sh; do
    [ -f "${skill_env}" ] && source "${skill_env}"
  done
fi

# Read samsara-bootstrap content for context injection
bootstrap_content=$(cat "${PLUGIN_DIR}/skills/samsara-bootstrap/SKILL.md" 2>&1 || echo "Error reading samsara-bootstrap skill")

# Escape string for JSON embedding.
# Handles: backslash, double-quote, newline, carriage-return, tab.
# Known gap: Unicode control characters (U+0000-U+001F) are not escaped.
# If SKILL.md contains raw control characters, JSON output will be malformed.
# This is a known limitation documented in the scar report.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<IMPORTANT>\nYou are operating under the Samsara framework (向死而驗).\n\n**Below is the full content of your 'samsara:samsara-bootstrap' skill:**\n\n${bootstrap_escaped}\n</IMPORTANT>"

# Output context injection as JSON for Codex — uses systemMessage field.
# IMPORTANT: Codex reads 'systemMessage' at the top level of the JSON output.
# Using any other field name causes silent context loss (Codex ignores unknown fields).
printf '{"systemMessage":"%s"}\n' "$session_context"

exit 0
